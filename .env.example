# Copia este archivo a .env.local para correr localmente con `vercel dev`.
# En producción, estas mismas variables se cargan en Vercel:
#   Project Settings -> Environment Variables.
# NUNCA subas el .env real al repo (ya está en .gitignore).

# --- Claude / Anthropic (obligatorio) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# --- Supabase (opcional: captura de leads del taller) ---
# Si los dejas vacíos, el demo funciona igual pero no registra leads.
# La service_role key es SECRETA: solo vive en el servidor, nunca en el front.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxx
